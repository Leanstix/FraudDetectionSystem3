# Team and model settings
TEAM_NAME=your-team-name
DEFAULT_MODEL=openai/gpt-4o-mini
DEFAULT_TEMPERATURE=0.2
LLM_ENABLED=true
AUDIO_TRANSCRIPTION_ENABLED=false
AUDIO_TRANSCRIPTION_ENGINE=none

# OpenRouter key (challenge key can also be named OPENROUTER_KEY_FOR_DATASET_1-3)
OPENROUTER_API_KEY=sk-or-...

# Langfuse settings (v3-compatible)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://challenges.reply.com/langfuse
LANGFUSE_MEDIA_UPLOAD_ENABLED=false

# Optional
OUTPUT_DIR=outputs
CACHE_DIR=cache
LLM_CACHE_DIR=cache/llm
RANDOM_SEED=42
REFERENCE_DECAY_DAYS=90
SUSPICIOUS_COMM_HALF_LIFE_HOURS=72
AUDIO_HALF_LIFE_HOURS=72
AUDIO_MATCH_WINDOW_HOURS=168
AUDIO_MAX_DURATION_SECONDS=7200
TARGET_FLAG_RATE=0.12
MIN_FLAG_RATE=0.02
MAX_FLAG_RATE=0.45
MIN_SCORE=0.15
MAX_SCORE=0.98
SCORE_FLOOR=0.35
